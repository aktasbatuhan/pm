-    def __init__(self, warmup_runs: int = 10, timing_runs: int = 100):
+    def __init__(
+        self,
+        warmup_runs: int = 10,
+        timing_runs: int = 100,
+        cublas_config: Optional[CuBLASBenchmarkConfig] = None,
+    ):
         self.warmup_runs = warmup_runs
         self.timing_runs = timing_runs
         self.profiler = PerformanceProfiler()
         self.results = []
+        self.cublas_config = cublas_config or CuBLASBenchmarkConfig()
+
+    @contextlib.contextmanager
+    def _scoped_cublas_settings(self, config: CuBLASBenchmarkConfig):
+        """Apply temporary backend settings for a fair cuBLAS benchmark."""
+        prev_tf32_matmul = torch.backends.cuda.matmul.allow_tf32
+        prev_tf32_cudnn = torch.backends.cudnn.allow_tf32
+        prev_precision = None
+        if hasattr(torch, "get_float32_matmul_precision"):
+            prev_precision = torch.get_float32_matmul_precision()
+
+        try:
+            if torch.cuda.is_available():
+                if config.disable_tf32:
+                    torch.backends.cuda.matmul.allow_tf32 = False
+                    torch.backends.cudnn.allow_tf32 = False
+                if prev_precision is not None:
+                    torch.set_float32_matmul_precision("highest")
+                torch.backends.cuda.preferred_blas_library(config.preferred_blas_library)
+            yield
+        finally:
+            torch.backends.cuda.matmul.allow_tf32 = prev_tf32_matmul
+            torch.backends.cudnn.allow_tf32 = prev_tf32_cudnn
+            if prev_precision is not None:
+                torch.set_float32_matmul_precision(prev_precision)
+            if torch.cuda.is_available():
+                torch.backends.cuda.preferred_blas_library("default")
+
+    def _measure_once(self, kernel_func, data: Tuple) -> float:
+        """Use CUDA events for GPU timing instead of wall-clock timers."""
+        device = data[0].device
+        if device.type == "cuda":
+            start_event = torch.cuda.Event(enable_timing=True)
+            end_event = torch.cuda.Event(enable_timing=True)
+            torch.cuda.synchronize()
+            start_event.record()
+            _ = kernel_func(data)
+            end_event.record()
+            torch.cuda.synchronize()
+            self.profiler.sample()
+            return start_event.elapsed_time(end_event)
+
+        start_time = time.perf_counter()
+        _ = kernel_func(data)
+        end_time = time.perf_counter()
+        return (end_time - start_time) * 1000
+
+    def _estimate_ops(self, operation: str, shape: Tuple[int, int, int]) -> float:
+        """Rough FLOP estimate for GEMV or batched GEMM."""
+        m, k, l = shape
+        if operation == "GEMV":
+            return 2.0 * m * k
+        return 2.0 * l * m * k * m
+
+    def _verify_cublas_dispatch(
+        self,
+        kernel_func,
+        data: Tuple,
+        expected_op: str,
+        config: CuBLASBenchmarkConfig,
+    ) -> Dict[str, Any]:
+        """Capture a profiler snapshot and verify ATen BLAS ops ran on CUDA."""
+        details = {
+            "verified": False,
+            "expected_op": expected_op,
+            "preferred_blas_library": config.preferred_blas_library,
+            "tf32_disabled": config.disable_tf32,
+            "cuda_available": torch.cuda.is_available(),
+        }
+        if not torch.cuda.is_available():
+            details["reason"] = "CUDA not available"
+            return details
+
+        try:
+            activities = [
+                torch.profiler.ProfilerActivity.CPU,
+                torch.profiler.ProfilerActivity.CUDA,
+            ]
+            with self._scoped_cublas_settings(config):
+                with torch.profiler.profile(activities=activities, record_shapes=True) as prof:
+                    _ = kernel_func(data)
+                torch.cuda.synchronize()
+
+            event_names = sorted({event.key for event in prof.key_averages()})
+            expected_event = f"aten::{expected_op}"
+            details["observed_ops"] = [name for name in event_names if name.startswith("aten::")]
+            details["verified"] = expected_event in event_names
+            if not details["verified"]:
+                details["reason"] = f"Expected profiler event {expected_event} not observed"
+        except Exception as exc:
+            details["reason"] = f"Profiler verification failed: {exc}"
+
+        return details
