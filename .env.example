# LLM Backend — pick one:

# Option 1: OpenRouter (recommended)
OPENROUTER_API_KEY=sk-or-v1-...

# Option 2: Anthropic direct
# ANTHROPIC_API_KEY=sk-ant-...

# Agent identity
AGENT_NAME=Dash
AGENT_MODEL=google/gemini-3-flash-preview

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org
GITHUB_PROJECT_NUMBER=1

# Slack Bot (optional — enables bi-directional Slack chat)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_DEFAULT_CHANNEL=#general

# Slack Webhook (optional — legacy one-way notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Web Search — Exa (optional)
EXA_API_KEY=...

# Meeting Notes — Granola (optional)
GRANOLA_API_KEY=...

# Auth (optional — leave empty for localhost/dev mode)
AUTH_TOKEN=

# Server
PORT=3000
